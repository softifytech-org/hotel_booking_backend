# ════════════════════════════════════════════
#  Hotel SaaS Backend — Environment Variables
# ════════════════════════════════════════════
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL — paste your connection string from pgAdmin/Supabase/Neon
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/hotel_saas_db

# JWT — generate strong secrets (run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_access_token_secret_here_min_64_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary — from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
